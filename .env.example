# Server
PORT=5000
NODE_ENV=production

# MongoDB (set this in Render environment variables)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster.mongodb.net/panditconnect?retryWrites=true&w=majority"

# JWT (use a strong random secret in production!)
JWT_SECRET="change-this-to-a-strong-random-secret"

# CORS — comma-separated list of extra origins to allow (Render env var)
# All *.vercel.app subdomains are allowed automatically
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app
